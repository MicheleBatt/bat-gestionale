<%
  type_class = case count.count_type
               when 'savings_account', 'savings_booklet'   then 'type-savings'
               when 'investments_account'                   then 'type-investments'
               when 'accumulation_plan'                     then 'type-accumulation'
               when 'postal_savings_bond'                   then 'type-postal'
               when 'pension_fund'                          then 'type-pension'
               when 'government_bond_investment_plan'       then 'type-government'
               when 'xau_investment_account', 'xag_investment_account' then 'type-metal'
               else ''
               end

  type_icon = case count.count_type
              when 'bank_account'                    then 'fa-building-columns'
              when 'savings_account'                 then 'fa-piggy-bank'
              when 'savings_booklet'                 then 'fa-book'
              when 'investments_account'             then 'fa-chart-line'
              when 'accumulation_plan'               then 'fa-layer-group'
              when 'postal_savings_bond'             then 'fa-stamp'
              when 'pension_fund'                    then 'fa-umbrella-beach'
              when 'government_bond_investment_plan' then 'fa-landmark'
              when 'xau_investment_account'          then 'fa-coins'
              when 'xag_investment_account'          then 'fa-gem'
              else 'fa-wallet'
              end
%>

<div class="count-card <%= type_class %>" id="count_<%= count.id %>">
  <div class="card-body-inner">
    <div class="card-top">
      <div class="card-type-icon">
        <i class="fas <%= type_icon %>"></i>
      </div>
      <div class="card-title-group">
        <%= link_to count.name, count.movements_default_path, class: "count-name" %>
        <span class="count-type-badge"><%= parsed_count_type(count.count_type) %></span>
      </div>
    </div>

    <% if count.description.present? %>
      <div class="count-description"><%= count.description %></div>
    <% end %>

    <% if count.iban.present? %>
      <div class="count-iban">
        <span id="count_<%= count.id %>_iban"><%= count.iban %></span>
        <button type="button"
                class="btn-copy"
                title="Copia IBAN"
                onclick="navigator.clipboard.writeText(document.querySelector('#count_<%= count.id %>_iban').innerText.trim())">
          <i class="fas fa-copy"></i>
        </button>
      </div>
    <% end %>

    <div class="card-bottom">
      <div class="balance-section">
        <div class="balance-label">Giacenza attuale</div>
        <div class="balance-amount <%= count.current_amount < 0 ? 'negative' : '' %>">
          <%= to_visible_amount(count.current_amount, false) %><span class="balance-currency">&euro;</span>
        </div>
      </div>

      <div class="card-actions">
        <button type="button"
                class="btn-action"
                title="Modifica"
                data-bs-toggle="modal"
                data-bs-target="#countEditingModal_<%= count.id %>">
          <i class="fas fa-pen-to-square"></i>
        </button>

        <% if count.movements.blank? %>
          <%= button_to organization_count_path(@organization, count),
                        method: :delete,
                        class: "btn-action btn-action-danger",
                        title: "Elimina" do %>
            <i class="fas fa-trash-can"></i>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%= render "modal",
             modal_id: "countEditingModal_#{count.id}",
             title: "Modifica conto",
             count: count
  %>
</div>
