<%
  icon_class, icon_svg = case count.count_type
    when 'bank_account'
      ['t-bank',   '<rect x="3" y="10" width="18" height="12"/><path d="M3 10l9-7 9 7"/><path d="M7 22v-5M12 22v-5M17 22v-5"/>']
    when 'savings_account'
      ['t-save',   '<ellipse cx="12" cy="13" rx="8" ry="7"/><path d="M9 6a6 6 0 014-2"/><path d="M8 13h3v4"/>']
    when 'savings_booklet'
      ['t-save',   '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M8 7h8M8 11h6M8 15h4"/>']
    when 'investments_account'
      ['t-invest', '<path d="M23 6l-9.5 9.5-5-5L1 18"/><path d="M17 6h6v6"/>']
    when 'accumulation_plan'
      ['t-accum',  '<path d="M12 2L2 7l10 5 10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>']
    when 'postal_savings_bond'
      ['t-postal', '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 5l10 7 10-7"/>']
    when 'pension_fund'
      ['t-pension','<path d="M23 12a11 11 0 00-22 0"/><path d="M12 12v8a3 3 0 006 0"/><path d="M12 2v2"/>']
    when 'government_bond_investment_plan'
      ['t-gov',    '<path d="M3 21h18M5 21V10M19 21V10M9 21v-6h6v6M3 10l9-7 9 7"/>']
    when 'xau_investment_account'
      ['t-metal',  '<circle cx="10" cy="14" r="6"/><circle cx="16" cy="10" r="6"/>']
    when 'xag_investment_account'
      ['t-metal',  '<path d="M6 3h12l4 7L12 22 2 10z"/><path d="M2 10h20"/>']
    else
      ['t-bank',   '<rect x="2" y="6" width="20" height="14" rx="2"/><path d="M2 10h20"/>']
    end
%>

<div class="v2-card"
     id="count_<%= count.id %>"
     onclick="window.location.href='<%= count.movements_default_path %>'">
  <div class="v2-card-top">
    <div class="v2-card-icon <%= icon_class %>">
      <svg class="ico" viewBox="0 0 24 24"><%= icon_svg.html_safe %></svg>
    </div>
    <div class="v2-card-title-group">
      <span class="v2-card-name"><%= count.name %></span>
      <span class="v2-card-badge"><%= parsed_count_type(count.count_type) %></span>
    </div>
  </div>

  <% if count.description.present? %>
    <div class="v2-card-desc"><%= count.description %></div>
  <% end %>

  <% if count.iban.present? %>
    <div class="v2-card-iban" onclick="event.stopPropagation();">
      <span id="count_<%= count.id %>_iban"><%= count.iban %></span>
      <button type="button"
              class="v2-btn-copy"
              title="Copia IBAN"
              onclick="event.stopPropagation(); navigator.clipboard.writeText(document.querySelector('#count_<%= count.id %>_iban').innerText.trim())">
        <svg class="ico-sm ico" viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      </button>
    </div>
  <% end %>

  <div class="v2-card-bottom">
    <div>
      <div class="v2-balance-label">Giacenza attuale</div>
      <div class="v2-balance-amount <%= count.current_amount < 0 ? 'neg' : '' %>">
        <%= to_visible_amount(count.current_amount, false) %><span class="v2-balance-currency">&euro;</span>
      </div>
    </div>

    <div class="v2-card-actions" onclick="event.stopPropagation();">
      <button type="button"
              class="v2-btn-icon"
              title="Modifica"
              data-bs-toggle="modal"
              data-bs-target="#countEditingModal_<%= count.id %>">
        <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M17 3a2.83 2.83 0 114 4L7.5 20.5 2 22l1.5-5.5z"/></svg>
      </button>

      <% if count.movements.blank? %>
        <%= button_to organization_count_path(@organization, count),
                      method: :delete,
                      class: "v2-btn-icon danger",
                      title: "Elimina" do %>
          <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/></svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
