<%= render 'layouts/navbar' %>

<div class="counts-dashboard page-counts-index">
  <%# === HERO BANNER === %>
  <div class="dashboard-hero">
    <div class="hero-content">
      <div class="hero-top">
        <div class="hero-title-section">
          <h1>I tuoi conti</h1>
          <span class="hero-subtitle"><%= @organization.name %></span>
        </div>
        <button type="button" class="btn-add-count" data-bs-toggle="modal" data-bs-target="#countCreationModal">
          <i class="fas fa-plus"></i> Nuovo conto
        </button>
      </div>
    </div>
  </div>

  <%# === SUMMARY METRICS (floating over hero) === %>
  <div class="summary-row">
    <div class="summary-card">
      <div class="summary-icon icon-accounts">
        <i class="fas fa-wallet"></i>
      </div>
      <div class="summary-info">
        <div class="summary-label">Conti attivi</div>
        <div class="summary-value"><%= @counts_count %></div>
      </div>
    </div>

    <div class="summary-card">
      <div class="summary-icon icon-balance <%= @counts_global_amount < 0 ? 'negative' : '' %>">
        <i class="fas fa-scale-balanced"></i>
      </div>
      <div class="summary-info">
        <div class="summary-label">Giacenza complessiva</div>
        <div class="summary-value <%= @counts_global_amount < 0 ? 'text-negative' : '' %>">
          <%= to_visible_amount(@counts_global_amount, false) %>&euro;
        </div>
      </div>
    </div>

    <% if @organization.movements.present? %>
      <div class="summary-card">
        <%= link_to stats_organization_path(id: @organization.id), class: "summary-link" do %>
          <div class="summary-icon icon-charts">
            <i class="fas fa-chart-pie"></i>
          </div>
          <div class="summary-info">
            <div class="summary-label">Analisi</div>
            <div class="summary-value">
              Visualizza grafici <i class="fas fa-arrow-right link-arrow"></i>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# === MAIN CONTENT === %>
  <div class="dashboard-content">
    <%# === FILTERS === %>
    <div class="filters-bar">
      <div class="filters-header">
        <i class="fas fa-sliders-h"></i>
        <h3 class="filters-title">Filtri</h3>
      </div>
      <%= search_form_for [@organization, @search], html: { class: 'filters-form' } do |f| %>
        <div class="filter-group">
          <%= f.label :name_cont, 'Nome' %>
          <%= f.text_field :name_cont, placeholder: 'Cerca per nome...', class: 'form-control' %>
        </div>

        <div class="filter-group">
          <%= f.label :count_type_eq, 'Tipo di conto' %>
          <%= f.select :count_type_eq,
                       options_for_select(count_types_for_select, @search.count_type_eq),
                       { include_blank: "Tutti i tipi" },
                       class: 'form-control form-select'
          %>
        </div>

        <div class="filter-actions">
          <button type="submit" class="btn-filter btn-filter-search">
            <i class="fas fa-search"></i> Cerca
          </button>
          <%= link_to organization_counts_path(@organization), class: "btn-filter btn-filter-reset" do %>
            <i class="fas fa-rotate-right"></i> Reset
          <% end %>
        </div>
      <% end %>
    </div>

    <%# === ACCOUNTS GRID === %>
    <% if @counts.any? %>
      <div class="section-header">
        <h2>Panoramica conti</h2>
        <span class="section-count"><%= @counts_count %> cont<%= @counts_count == 1 ? 'o' : 'i' %></span>
      </div>

      <div id="counts" class="counts-grid">
        <% @counts.each do |count| %>
          <%= render count %>
        <% end %>
      </div>
    <% else %>
      <div class="counts-empty">
        <div class="empty-icon">
          <i class="fas fa-vault"></i>
        </div>
        <h3>Nessun conto trovato</h3>
        <p>Modifica i filtri di ricerca oppure aggiungi il tuo primo conto per iniziare.</p>
        <button type="button" class="btn-empty-add" data-bs-toggle="modal" data-bs-target="#countCreationModal">
          <i class="fas fa-plus"></i> Aggiungi conto
        </button>
      </div>
    <% end %>
  </div>
</div>

<%# === MODAL CREAZIONE === %>
<%= render "modal",
           modal_id: "countCreationModal",
           title: "Aggiungi un nuovo conto",
           count: Count.new
%>
