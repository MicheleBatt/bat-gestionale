<%= form_with(model: [@organization, count]) do |form| %>
  <%= form.hidden_field :organization_id, value: @organization.id %>
  <%= form.hidden_field :modal_id, value: modal_id %>

  <div class="m-4">
    <%= form.label :name, 'Nome', class: "form-label" %>
    <%= form.text_field :name, class: "form-control" %>
  </div>

  <div class="m-4">
    <%= form.label :description, 'Descrizione (opzionale)', class: "form-label" %>
    <%= form.text_area :description, class: "form-control" %>
  </div>

  <div class="m-4">
    <%= form.label :count_type, 'Tipo', class: "form-label" %>
    <%= form.select :count_type,
                    options_for_select(count_types_for_select, count.count_type),
                    { include_blank: 'Specifica il tipo di conto' },
                    class: 'form-control',
                    data: { metal_types: CountsHelper::METALS_COUNT_TYPES.to_json }
    %>
  </div>

  <div class="m-4">
    <%= form.label :iban, 'Codice IBAN', class: "form-label" %>
    <%= form.text_field :iban, class: "form-control" %>
  </div>

  <div class="m-4">
    <%= form.label :monitoring_scope, 'Monitoraggio', class: "form-label" %>
    <%= form.select :monitoring_scope,
                    options_for_select(monitoring_scopes_for_select, count.monitoring_scope),
                    { include_blank: false },
                    class: 'form-control'
    %>
  </div>

  <div class="m-4">
    <%= form.label :initial_amount, 'Giacenza Iniziale', class: "form-label" %>
    <div class="v2-input-group">
      <%= form.number_field :initial_amount, step: :any, class: "form-control" %>
      <span class="v2-input-group-unit" id="<%= modal_id %>_unit_label"><%= count.metal_account? ? 'g' : '€' %></span>
    </div>
  </div>

  <div class="m-4">
    <%= form.label :ordering_number, 'Ordinamento', class: "form-label" %>
    <%= form.number_field :ordering_number, class: "form-control" %>
  </div>

  <% if count.persisted? && count.movements.present? %>
    <div class="m-4" style="border: 1px solid #dc2626; border-radius: 8px; padding: 1rem; background: rgba(220, 38, 38, 0.05);">
      <div class="form-check">
        <%= form.check_box :deleted, class: "form-check-input close-count-check", id: "#{modal_id}_deleted_flag", style: "border-color: #dc2626;" %>
        <%= form.label :deleted, 'Chiudi conto', class: "form-check-label", for: "#{modal_id}_deleted_flag", style: "color: #dc2626; font-weight: 600; font-size: 0.85rem;" %>
      </div>
      <p style="color: var(--txt2); font-size: 0.8rem; margin: 0.6rem 0 0; line-height: 1.5;">
        Attivando questa opzione il conto verrà chiuso definitivamente. Da quel momento non sarà più possibile
        gestire la contabilità di questo conto (registrare nuovi movimenti, modificare quelli esistenti, ecc.).
        Tutti i movimenti registrati in passato resteranno comunque archiviati a sistema a fini di consultazione storica.
        <strong style="color: #dc2626;">Questa operazione è irreversibile e non potrà essere annullata.</strong>
      </p>
    </div>
  <% end %>

  <div class="mt-4 d-flex flex-wrap justify-content-between">
    <button type="button" class="btn btn-secondary mx-2 mx-sm-4 my-2" data-bs-dismiss="modal">Annulla</button>

    <%= form.button :submit, class: 'btn btn-success mx-2 mx-sm-4 my-2' do %>
      Salva
    <% end %>
  </div>

  <script>
    (function() {
      var modal = document.getElementById('<%= modal_id %>');
      if (!modal) return;
      var select = modal.querySelector('select[name*="count_type"]');
      var unitLabel = document.getElementById('<%= modal_id %>_unit_label');
      if (select && unitLabel) {
        var metalTypes = JSON.parse(select.dataset.metalTypes);
        select.addEventListener('change', function() {
          unitLabel.textContent = metalTypes.includes(this.value) ? 'g' : '€';
        });
      }
    })();
  </script>
<% end %>
