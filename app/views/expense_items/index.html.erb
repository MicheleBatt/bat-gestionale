<div class="v2">
  <%= render 'layouts/aurora_background' %>

  <%# Navbar %>
  <%= render 'layouts/navbar_v2' %>

  <%# Main content %>
  <main class="v2-main">
    <%# Hero %>
    <header class="v2-hero">
      <div>
        <h1 class="v2-hero-title">Voci di spesa</h1>
        <span class="v2-hero-sub"><%= @organization.name %></span>
      </div>
      <button type="button" class="v2-btn-primary" data-bs-toggle="modal" data-bs-target="#expense_itemCreationModal">
        <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
        Nuova voce di spesa
      </button>
    </header>

    <%# Filters (accordion) %>
    <section class="v2-filters">
      <div class="accordion" id="v2FiltersAccordion">
        <div class="accordion-item v2-accordion-item">
          <h2 class="accordion-header">
            <button class="accordion-button v2-accordion-btn" type="button" data-bs-toggle="collapse" data-bs-target="#v2FiltersBody" aria-expanded="true" aria-controls="v2FiltersBody">
              <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6"/></svg>
              Filtri
            </button>
          </h2>
          <div id="v2FiltersBody" class="accordion-collapse collapse show" data-bs-parent="#v2FiltersAccordion">
            <div class="accordion-body v2-accordion-body">
              <%= search_form_for [@organization, @search], html: { class: 'v2-filters-form' } do |f| %>
                <div class="v2-filter-group">
                  <%= f.label :description_cont, 'Descrizione' %>
                  <%= f.text_field :description_cont, placeholder: 'Cerca per descrizione...', class: 'v2-input' %>
                </div>
                <div class="v2-filter-actions">
                  <button type="submit" class="v2-btn-search">
                    <svg class="ico ico-sm" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
                    Cerca
                  </button>
                  <%= link_to organization_expense_items_path(@organization), class: "v2-btn-reset", data: { turbo: false } do %>
                    <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M1 4v6h6M23 20v-6h-6"/><path d="M20.49 9A9 9 0 005.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 013.51 15"/></svg>
                    Reset
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <%# List %>
    <% if @expense_items.any? %>
      <div class="v2-section-head">
        <h2 class="v2-section-title">Elenco voci</h2>
        <span class="v2-section-badge"><%= @expense_items_count %> voc<%= @expense_items_count == 1 ? 'e' : 'i' %></span>
      </div>

      <div id="expense_items" class="v2-ei-list">
        <% @expense_items.each do |expense_item| %>
          <%= render expense_item %>
        <% end %>
      </div>
    <% else %>
      <div class="v2-empty">
        <div class="v2-empty-icon">
          <svg class="ico ico-lg" viewBox="0 0 24 24"><path d="M4 4h7l9 9-7 7-9-9V4z"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        </div>
        <h3>Nessuna voce di spesa trovata</h3>
        <p>Modifica i filtri di ricerca oppure aggiungi la tua prima voce di spesa.</p>
        <button type="button" class="v2-btn-ghost" data-bs-toggle="modal" data-bs-target="#expense_itemCreationModal">
          <svg class="ico ico-sm" viewBox="0 0 24 24"><path d="M12 5v14M5 12h14"/></svg>
          Aggiungi voce di spesa
        </button>
      </div>
    <% end %>
  </main>
</div>

<%# Modals (fuori da .v2 per evitare problemi di stacking context) %>
<div class="v2">
  <%= render "modal",
             modal_id: "expense_itemCreationModal",
             title: "Aggiungi una voce di spesa",
             expense_item: ExpenseItem.new
  %>

  <% @expense_items.each do |expense_item| %>
    <%= render "modal",
               modal_id: "expense_itemEditingModal_#{expense_item.id}",
               title: "Modifica voce di spesa",
               expense_item: expense_item
    %>

    <% if expense_item.movements.blank? %>
      <div class="modal fade" id="expense_itemDeleteModal_<%= expense_item.id %>" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h4 class="modal-title fs-5">Conferma cancellazione</h4>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <p style="color: var(--txt2); font-size: 0.88rem; margin: 0.5rem 0;">
                Sei sicuro di voler eliminare la voce di spesa <strong style="color: var(--txt);"><%= expense_item.description %></strong>?
              </p>
              <p style="color: var(--txt3); font-size: 0.78rem; margin: 0 0 1.5rem;">
                Questa azione non può essere annullata.
              </p>
              <div style="display: flex; justify-content: space-between; align-items: center;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                <%= button_to organization_expense_item_path(@organization, expense_item),
                              method: :delete,
                              class: "btn btn-success",
                              style: "background: #dc2626; border-color: #dc2626;" do %>
                  Conferma
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<%= render 'layouts/auto_close_modals' %>
