<% movements.each do |movement| %>
  <div class="v2-mov-row">
    <% if movement.movement_type == 'out' %>
      <%= render movement, expense_items: expense_items, movement_types: movement_types %>
      <div class="v2-mov-empty"></div>
    <% else %>
      <div class="v2-mov-empty"></div>
      <%= render movement, expense_items: expense_items, movement_types: movement_types %>
    <% end %>
  </div>
<% end %>

<% if movements.count >= per_page %>
  <div id="movements-container-<%= page.to_i %>">
    <div class="v2-mov-load-more">
      <%= link_to 'Carica altri',
                  organization_count_movements_path(organization_id: organization, count_id: count.id, q: { **params[:q]&.to_unsafe_h }, page: page.to_i),
                  data: { turbo_stream: true },
                  method: :get
      %>
    </div>
  </div>
<% end %>
