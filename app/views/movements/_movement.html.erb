<div class="v2-mov-cell <%= movement.movement_type == 'out' ? 'out-cell' : '' %> <%= @count.metal_account? ? 'metal-cell' : '' %>"
     id="movement_<%= movement.id %>"
     style="--mov-color: <%= movement.expense_item&.color || 'transparent' %>">
  <div class="v2-mov-date"><%= parse_date(movement.emitted_at, '%d.%m.%y') %></div>
  <% if can? :update, Movement %>
    <div class="v2-mov-causal"
         data-bs-toggle="modal"
         data-bs-target="#movementEditingModal_<%= movement.id %>">
      <%= movement.causal %>
      <% if @count.metal_account? && movement.karat.present? %>
        <span style="color: var(--txt3); font-size: 0.65rem; margin-left: 0.3rem;">
          <%= movement.karat.to_i %>k
        </span>
      <% end %>
    </div>
  <% else %>
    <div class="v2-mov-causal" style="cursor: default;">
      <%= movement.causal %>
      <% if @count.metal_account? && movement.karat.present? %>
        <span style="color: var(--txt3); font-size: 0.65rem; margin-left: 0.3rem;"><%= movement.karat.to_i %>k</span>
      <% end %>
    </div>
  <% end %>
  <% if @count.metal_account? %>
    <div class="v2-mov-metal-col"><%= movement.value > 0 ? "#{to_visible_amount(movement.value, false)}€" : '' %></div>
    <div class="v2-mov-metal-col"><%= movement.spread.present? ? "#{movement.spread > 0 ? '+' : ''}#{to_visible_amount(movement.spread, false)}%" : '' %></div>
    <div class="v2-mov-metal-col"><%= movement.price_per_gram_at_transaction.present? ? "#{to_visible_amount(movement.price_per_gram_at_transaction, false)}€" : '' %></div>
    <div class="v2-mov-metal-col"><%= movement.price_at_transaction.present? ? "#{to_visible_amount(movement.price_at_transaction, false)}€" : '' %></div>
    <div class="v2-mov-metal-group">
      <div class="v2-mov-metal-group-item">
        <span class="v2-mov-metal-group-label">Valore/g</span>
        <span class="v2-mov-metal-group-value"><%= movement.value > 0 ? "#{to_visible_amount(movement.value, false)}€" : '-' %></span>
      </div>
      <div class="v2-mov-metal-group-item">
        <span class="v2-mov-metal-group-label">Spread</span>
        <span class="v2-mov-metal-group-value"><%= movement.spread.present? ? "#{movement.spread > 0 ? '+' : ''}#{to_visible_amount(movement.spread, false)}%" : '-' %></span>
      </div>
      <div class="v2-mov-metal-group-item">
        <span class="v2-mov-metal-group-label">Prezzo/g</span>
        <span class="v2-mov-metal-group-value"><%= movement.price_per_gram_at_transaction.present? ? "#{to_visible_amount(movement.price_per_gram_at_transaction, false)}€" : '-' %></span>
      </div>
      <div class="v2-mov-metal-group-item">
        <span class="v2-mov-metal-group-label">Totale</span>
        <span class="v2-mov-metal-group-value"><%= movement.price_at_transaction.present? ? "#{to_visible_amount(movement.price_at_transaction, false)}€" : '-' %></span>
      </div>
      <div class="v2-mov-metal-group-item">
        <span class="v2-mov-metal-group-label">Grammi</span>
        <span class="v2-mov-metal-group-value <%= movement.movement_type %>"><%= movement.movement_type == 'in' ? '+' : '-' %><%= to_visible_amount(movement.amount) %>g</span>
      </div>
    </div>
  <% end %>
  <div class="v2-mov-amount <%= movement.movement_type %>">
    <span class="d-inline d-lg-none"><%= movement.movement_type == 'in' ? '+' : '-' %></span><%= to_visible_amount(movement.amount) %><%= @count.metal_account? ? 'g' : '€' %>
  </div>
</div>

<% if can? :update, Movement %>
  <%= render "modal",
             modal_id: "movementEditingModal_#{movement.id}",
             title: @count.metal_account? ? (movement.movement_type == 'out' ? "Modifica Vendita" : "Modifica Acquisto") : (movement.movement_type == 'out' ? "Modifica Uscita" : "Modifica Entrata"),
             movement: movement,
             expense_items: expense_items,
             movement_types: movement_types,
             deletion_path: organization_count_movement_path(@organization, @count, movement)
  %>
<% end %>
