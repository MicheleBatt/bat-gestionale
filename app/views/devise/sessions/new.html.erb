<div class="v2">
  <%= render 'layouts/aurora_background' %>

  <div class="v2-login-wrapper">
    <div class="v2-login-card">
      <div class="v2-login-header">
        <h1 class="v2-login-title">BatGestionale</h1>
        <p class="v2-login-subtitle">Accedi al tuo account</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="v2-login-field">
          <%= f.label :email, 'Email', class: "v2-login-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "v2-input", placeholder: "nome@esempio.com" %>
        </div>

        <div class="v2-login-field">
          <%= f.label :password, 'Password', class: "v2-login-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "v2-input", placeholder: "La tua password" %>
        </div>

        <div class="v2-login-remember">
          <label class="v2-login-remember-label">
            <%= f.check_box :remember_me, class: "v2-login-checkbox" %>
            <span>Ricordami</span>
          </label>
        </div>

        <div class="v2-login-actions">
          <%= f.submit "Accedi", class: "v2-login-btn" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
